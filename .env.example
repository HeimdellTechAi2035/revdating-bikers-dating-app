# =============================================================
# REVdating — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in values for local dev.
# NEVER commit .env.local or production secrets to version control.

# ---------------------------------------------------------------
# SUPABASE (required in production)
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-jwt-secret

# ---------------------------------------------------------------
# APP
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=REVdating
INTERNAL_WEBHOOK_SECRET=generate-a-strong-random-string-here

# Explicit local/dev-only preview bypass. Disabled by default and ignored in production.
DEV_BYPASS_AUTH=false

# Optional demo reviewer login. Disabled by default.
# NEXT_PUBLIC_DEMO_LOGIN_PASSWORD is browser-visible when enabled. Use only
# with a throwaway demo account, never a real user account, and keep disabled
# in normal production.
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=false
NEXT_PUBLIC_DEMO_LOGIN_EMAIL=
NEXT_PUBLIC_DEMO_LOGIN_PASSWORD=

# ---------------------------------------------------------------
# STRIPE (required for premium checkout / billing)
# ---------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_RIDER_PLUS_MONTHLY=price_...
STRIPE_PRICE_RIDER_PLUS_YEARLY=price_...
STRIPE_PRICE_RIDER_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_RIDER_PREMIUM_YEARLY=price_...
# Legacy aliases still supported by the code for Rider Plus:
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# ---------------------------------------------------------------
# EMAIL — Resend (transactional / re-engagement emails)
# ---------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=REVdating <noreply@yourdomain.com>

# ---------------------------------------------------------------
# MAPS — Google Maps (ride date location search + previews)
# ---------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ---------------------------------------------------------------
# IMAGE MODERATION — Sightengine (optional; app falls back safely)
# ---------------------------------------------------------------
SIGHTENGINE_API_USER=your-api-user
SIGHTENGINE_API_SECRET=your-api-secret

# ---------------------------------------------------------------
# WEB PUSH — VAPID (current push implementation)
# ---------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@yourdomain.com

# Legacy OneSignal variables are not used by the current code path.
# Keep unset unless you reintroduce OneSignal integration.
# NEXT_PUBLIC_ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=

# ---------------------------------------------------------------
# ERROR TRACKING — Sentry (recommended)
# ---------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=REVdating

# ---------------------------------------------------------------
# ANALYTICS — PostHog (recommended)
# ---------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---------------------------------------------------------------
# TENOR — GIF picker in chat (falls back to demo key if unset)
# ---------------------------------------------------------------
TENOR_API_KEY=LIVDSRZULELA
