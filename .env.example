# =============================================================
# RevMatch — Biker Dating App — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.

# ---------------------------------------------------------------
# SUPABASE (required)
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---------------------------------------------------------------
# APP
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RevMatch

# ---------------------------------------------------------------
# STRIPE (required for premium features)
# ---------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ---------------------------------------------------------------
# EMAIL — Resend (required for transactional / re-engagement emails)
# Get API key at https://resend.com — free tier: 3,000 emails/month
# RESEND_FROM_EMAIL must be from a verified sending domain in Resend
# ---------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=RevMatch <noreply@yourdomain.com>

# ---------------------------------------------------------------
# MAPS — Google Maps (required for ride date location search + previews)
# Enable APIs: Maps JavaScript API, Places API, Maps Static API
# Get keys at https://console.cloud.google.com/apis
# ---------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ---------------------------------------------------------------
# IMAGE MODERATION — Sightengine (required for photo moderation)
# Get keys at https://sightengine.com
# ---------------------------------------------------------------
SIGHTENGINE_API_USER=your-api-user
SIGHTENGINE_API_SECRET=your-api-secret

# ---------------------------------------------------------------
# PUSH NOTIFICATIONS — OneSignal (required for push)
# Get keys at https://onesignal.com
# ---------------------------------------------------------------
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ---------------------------------------------------------------
# ERROR TRACKING — Sentry (recommended)
# Get keys at https://sentry.io
# ---------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org

# ---------------------------------------------------------------
# ANALYTICS — PostHog (recommended)
# Get keys at https://posthog.com
# ---------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---------------------------------------------------------------
# SUPABASE (additional — for local dev)
# ---------------------------------------------------------------
# Only needed if you use Supabase CLI for local development
SUPABASE_JWT_SECRET=your-jwt-secret
SENTRY_PROJECT=revmatch

# ---------------------------------------------------------------
# PRODUCT ANALYTICS — PostHog (recommended)
# Get keys at https://posthog.com
# ---------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---------------------------------------------------------------
# TENOR — GIF picker in chat (free API key at tenor.com/gifapi)
# Falls back to the public demo key if not set (works out of the box)
# ---------------------------------------------------------------
TENOR_API_KEY=LIVDSRZULELA

# ---------------------------------------------------------------
# INTERNAL SECRETS
# ---------------------------------------------------------------
# Secret used to sign internal webhook payloads
INTERNAL_WEBHOOK_SECRET=generate-a-strong-random-string-here
